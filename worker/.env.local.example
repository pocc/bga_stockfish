# Wrangler auto-loads worker/.env.local at deploy/dev time.
# Copy this file to .env.local and fill in the values once; then
# `npx wrangler deploy` runs without any further setup.

# Cloudflare account (visible in the URL when you log into the dashboard).
CLOUDFLARE_ACCOUNT_ID=

# Cloudflare API token with "Edit Cloudflare Workers" permission.
# Create at: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=
